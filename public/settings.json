{
    "NAME": "1001 Seaforest Species",
    "PACKAGE_NAME": "org.localcosmos.seaforestspecies",
    "LANGUAGES": [
        "en"
    ],
    "PRIMARY_LANGUAGE": "en",
    "APP_UID": "seaforest",
    "APP_UUID": "b3b4bb97-82dc-486d-9f71-e464d690e100",
    "APP_VERSION": 1,
    "BUILD_NUMBER": 8,
    "API_URL": "http://seaforest.tomwork.sisol:8000/api/",
    "MEDIA_URL": "http://seaforest.tomwork.sisol:8000/media/",
    "SERVER_URL": "http://seaforest.tomwork.sisol:8000/",
    "PREVIEW": true,
    "OPTIONS": {
        "allowAnonymousObservations": false,
        "doNotBuildLargeImages": false
    },
    "frontend": "Sea Change Project",
    "version": "0.7",
    "userContent": {
        "configuration": {
            "geonamesUsername": {
                "required": false,
                "helpText": "Enables Geonames search functionality"
            }
        },
        "images": {
            "appLauncherIcon": {
                "restrictions": {
                    "fileType": [
                        "svg"
                    ],
                    "ratio": "1:1"
                },
                "helpText": "Has to be an .SVG vector graphic AND the ratio must be 1:1. Will be displayed on your phones home screen to launch your app",
                "required": true
            },
            "appSplashscreen": {
                "restrictions": {
                    "fileType": [
                        "svg"
                    ],
                    "ratio": "1:1"
                },
                "helpText": "Will be displayed during app startup",
                "required": true
            },
            "logo": {
                "restrictions": {
                    "fileType": [
                        "svg"
                    ]
                },
                "helpText": "Will be displayed on the apps main page",
                "required": true
            },
            "favicon": {
                "restrictions": {
                    "fileType": [
                        "png",
                        "webp"
                    ],
                    "ratio": "1:1"
                },
                "helpText": "Will be displayed in the browser tab",
                "required": true
            },
            "backgroundImage": {
                "restrictions": {
                    "fileType": [
                        "png",
                        "jpg",
                        "webp"
                    ],
                    "ratio": "1:2"
                },
                "helpText": "Will be displayed in the background of the app's main page",
                "required": false
            },
            "landscapeBackgroundImage": {
                "restrictions": {
                    "fileType": [
                        "png",
                        "jpg",
                        "webp"
                    ],
                    "ratio": "2:1"
                },
                "helpText": "Will be displayed in the background of the app's main page when device is in landscape mode",
                "required": false
            }
        },
        "texts": {
            "termsOfUse": {
                "required": false,
                "helpText": "Terms of Use"
            }
        }
    },
    "templateContent": {
        "urlPattern": "/pages/{templateName}/{slug}/",
        "navigations": {
            "main": {
                "name": "Main navigation",
                "maxLevels": 1,
                "maxEntries": 1
            },
            "burger": {
                "name": "Burger menu",
                "maxLevels": 1
            }
        },
        "requiredOfflineContents": {}
    },
    "cordova": {
        "platforms": {
            "android": "android@15.0.0",
            "ios": "ios@8.0.1",
            "browser": "browser@7.0.0"
        },
        "plugins": [
            "cordova-plugin-device@2.1.0",
            "cordova-plugin-statusbar@3.0.0",
            "cordova-plugin-wkwebview-file-xhr@3.1.0",
            "cordova-plugin-assetpack"
        ]
    }
}